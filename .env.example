# API: Store Backend (memory for dev, supabase for production)
STORE_BACKEND=supabase

# API: CORS Configuration (for production: https://app.example.com,https://api.example.com)
CORS_ORIGINS=

# Shared Configuration
EVENT_SOURCE_TIMEZONE=Asia/Singapore
WEB_APP_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000

# Frontend: Vite Environment
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend Worker Configuration
WORKER_API_BASE_URL=http://localhost:8000
