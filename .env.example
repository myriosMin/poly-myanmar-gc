# API Environment Mode (development or production)
ENVIRONMENT=development

# API: Supabase Configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# API: Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=
